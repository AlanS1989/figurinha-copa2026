{
  "version": 2,
  "functions": {
    "api/gerar.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/webhook.js": {
      "maxDuration": 30
    },
    "api/checkout.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
